# Auth service API base URL
# In local development, use Vite proxy path to avoid CORS and forward to auth.fduhole.com.
VITE_AUTH_API_URL=/api/auth

# Treehole service API base URL
# In local development, use Vite proxy path to forward to forum.fduhole.com.
VITE_TREEHOLE_API_URL=/api/treehole

# Request timeout (ms)
VITE_SERVER_API_TIMEOUT=5000